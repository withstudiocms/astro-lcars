---
import { getRandomLCARSLoadingMessage } from "../lib/random";
import { NAV } from "../lib/nav";
import LElement from "./LElement.astro";
import TextBox from "./TextBox.astro";

interface Props {
    siteTitle: string;
    pageKey: string;
}

const { siteTitle, pageKey } = Astro.props;
---

<div class="lcars-app-container">
    <div id="header" class="lcars-row header">
        {/* ELBOW */}
        <div class="lcars-elbow left-bottom"></div>

        {/* BAR WITH TITLE */}
        <div class="lcars-bar horizontal">
            <div class="lcars-title right">{siteTitle}</div>
        </div>

        {/* ROUNDED EDGE DECORATED */}
        <div class="lcars-bar horizontal right-end decorated"></div>
    </div>

    <div
        id="left-menu"
        class="lcars-column start-space lcars-u-1"
        style="text-transform: uppercase;"
    >
        {/* Primary Navigation Links */}
        {
            NAV.map((navItem) => (
                <a href={pageKey === navItem.key ? undefined : navItem.href}>
                    <LElement
                        color={navItem.color || "golden-tanoi"}
                        button
                        classList={
                            pageKey === navItem.key ? "nav active" : "nav"
                        }
                    >
                        {navItem.text}
                    </LElement>
                </a>
            ))
        }

        {
            /* Spacer and filler elements to push the nav to the top and add some visual interest */
        }
        <div class="lcars-bar fill lcars-u-1"></div>
        <div class="lcars-bar spacer"></div>

        {/* Link to source code on GitHub */}
        <a href="https://github.com/Adammatthiesen/astro-lcars" target="_blank">
            <LElement button classList="nav" color="atomic-tangerine">
                Source Code
            </LElement>
        </a>

        {
            /* Decorative elements to fill out the left menu and add visual interest */
        }
        <div class="lcars-bar lock-bottom lcars-u-1"></div>
    </div>

    <div id="footer" class="lcars-row">
        {/* ELBOW */}
        <div class="lcars-elbow left-top"></div>
        {/* BAR */}
        <div class="lcars-bar horizontal both-divider bottom">
            <div class="lcars-copy left">
                MIT Licensed {new Date().getFullYear()} - {siteTitle}.
            </div>
            <div class="lcars-copy right">
                LCARS is a copyright of CBS Studios INC. All rights reserved.
                This website is not affiliated with or endorsed by CBS in any
                way.
            </div>
        </div>
        {/* ROUNDED EDGE */}
        <div class="lcars-bar horizontal right-end left-divider bottom"></div>
    </div>

    <div id="loading-screen" class="overlay">
        <TextBox textSize="huge" position="full-centered" u={8} blink
            >{getRandomLCARSLoadingMessage()}</TextBox
        >
    </div>

    <div id="container">
        <slot />
    </div>
</div>

<script is:inline>
    function ready() {
        setTimeout(() => {
            const app = document.querySelector(".lcars-app-container");
            app?.classList.add("is-ready");
            lcarsAudio.Ready();
        }, 250);
    }

    document.addEventListener("DOMContentLoaded", ready);
</script>
